generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Unit {
  id         String      @id @default(cuid())
  name       String
  status     String      @default("available")
  prospects  Prospect[]
}

model Prospect {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  phone          String?
  status         String   @default("new")
  assignee       String?
  assignedUnitId String?
  unit           Unit?    @relation(fields: [assignedUnitId], references: [id])
}
